# ── Model files (too large for git, download separately) ─────────────────────
models/
*.keras
*.h5
*.pb

# ── User uploads (runtime temp files) ────────────────────────────────────────
uploads/*
!uploads/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env

# ── Jupyter / Kaggle ──────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/